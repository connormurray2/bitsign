generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Document {
  id            String        @id @default(cuid())
  title         String
  s3Key         String        @unique
  sha256        String
  creatorKey    String
  status        DocStatus     @default(PENDING)
  isMultisig    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  expiresAt     DateTime?
  folderId      String?
  folder        Folder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)

  signers       Signer[]
  signingEvents SigningEvent[]
  fields        SigningField[]

  @@index([creatorKey])
  @@index([status])
}

enum DocStatus {
  PENDING
  COMPLETE
  EXPIRED
  CANCELLED
}

model Signer {
  id           String       @id @default(cuid())
  documentId   String
  document     Document     @relation(fields: [documentId], references: [id])
  identityKey  String
  handle       String?
  order        Int
  status       SignerStatus  @default(PENDING)
  token        String       @unique @default(cuid())
  notifiedAt       DateTime?
  partialSig       String?      // DER hex ECDSA sig of docHash (multisig pre-broadcast)
  partialSigPubkey String?      // BRC-43 derived pubkey for partialSig
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  signingEvent SigningEvent?

  @@unique([documentId, identityKey])
  @@index([documentId])
  @@index([token])
}

enum SignerStatus {
  PENDING
  NOTIFIED
  SIGNED
}

model Contact {
  id          String   @id @default(cuid())
  ownerKey    String                        // identity key of the person who saved this contact
  identityKey String                        // identity key of the contact
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerKey, identityKey])
  @@index([ownerKey])
}

model SigningEvent {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  signerId    String   @unique
  signer      Signer   @relation(fields: [signerId], references: [id])
  identityKey String
  txid        String
  outputIndex Int      @default(0)
  docHash     String
  ecdsaSig          String
  timestamp         DateTime
  rawTx             String?
  lockingScriptHex  String?
  createdAt         DateTime @default(now())

  @@index([documentId])
  @@index([identityKey])
  @@index([txid])
}

model Folder {
  id        String     @id @default(cuid())
  ownerKey  String
  name      String
  createdAt DateTime   @default(now())

  documents Document[]

  @@index([ownerKey])
}

model SigningField {
  id                String    @id @default(cuid())
  documentId        String
  document          Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  type              String    // "signature" | "initials" | "date" | "text"
  page              Int
  x                 Float
  y                 Float
  width             Float
  height            Float
  assignedSignerKey String
  value             String?   // filled in when signer completes field
  completedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([documentId])
}

model UserProfile {
  id               String               @id @default(cuid())
  identityKey      String               @unique
  firstName        String
  lastName         String
  signatureS3Key   String
  signatureHash    String
  initialsS3Key    String?
  initialsHash     String?
  registrationTxid String
  commitmentHash   String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  registrations    ProfileRegistration[]

  @@index([identityKey])
}

model ProfileRegistration {
  id             String      @id @default(cuid())
  identityKey    String
  profile        UserProfile @relation(fields: [identityKey], references: [identityKey])
  txid           String      @unique
  commitmentHash String
  firstName      String
  lastName       String
  signatureS3Key String
  signatureHash  String
  initialsS3Key  String?
  initialsHash   String?
  createdAt      DateTime    @default(now())

  @@index([identityKey])
}
